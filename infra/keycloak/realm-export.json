{
  "realm": "sepa-nexus",
  "enabled": true,
  "organizationsEnabled": true,
  "requiredActions": [
    { "alias": "VERIFY_PROFILE", "enabled": false, "defaultAction": false, "priority": 10 }
  ],
  "roles": {
    "realm": [
      { "name": "operator" },
      { "name": "payment_viewer" },
      { "name": "payment_submitter" },
      { "name": "payment_approver" },
      { "name": "settlement_operator" },
      { "name": "egress_operator" },
      { "name": "reconciliation_operator" },
      { "name": "case_operator" },
      { "name": "reference_data_admin" },
      { "name": "simulation_operator" },
      { "name": "auditor" },
      { "name": "security_admin" }
    ]
  },
  "clientScopes": [
    {
      "name": "sepa-guc",
      "description": "SEPA Nexus organization and branch claims for the BFF and resource server",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "organization",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-membership-mapper",
          "config": {
            "claim.name": "organization",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true",
            "addOrganizationId": "true",
            "addOrganizationAttributes": "true"
          }
        },
        {
          "name": "branch_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "branch_id",
            "claim.name": "branch_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "sepa-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-only-sepa-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "defaultClientScopes": ["sepa-guc"]
    },
    {
      "clientId": "sepa-api",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "sepa-integration",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-only-sepa-integration-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "organizations": [
    {
      "id": "00000000-0000-0000-0000-000000000010",
      "name": "Demo Bank Organization",
      "alias": "demo-bank-org",
      "enabled": true,
      "attributes": { "tenant_id": ["00000000-0000-0000-0000-000000000001"] },
      "members": [
        { "username": "operator", "membershipType": "UNMANAGED" },
        { "username": "viewer", "membershipType": "UNMANAGED" },
        { "username": "submitter", "membershipType": "UNMANAGED" },
        { "username": "approver", "membershipType": "UNMANAGED" },
        { "username": "settlement", "membershipType": "UNMANAGED" },
        { "username": "egress", "membershipType": "UNMANAGED" },
        { "username": "reconciliation", "membershipType": "UNMANAGED" },
        { "username": "case", "membershipType": "UNMANAGED" },
        { "username": "refdata", "membershipType": "UNMANAGED" },
        { "username": "simulation", "membershipType": "UNMANAGED" },
        { "username": "auditor", "membershipType": "UNMANAGED" },
        { "username": "security-admin", "membershipType": "UNMANAGED" }
      ]
    }
  ],
  "users": [
    { "username": "operator", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["operator"], "credentials": [{ "type": "password", "value": "dev-only-operator", "temporary": false }] },
    { "username": "viewer", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["payment_viewer"], "credentials": [{ "type": "password", "value": "dev-only-viewer", "temporary": false }] },
    { "username": "submitter", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["payment_submitter"], "credentials": [{ "type": "password", "value": "dev-only-submitter", "temporary": false }] },
    { "username": "approver", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["payment_approver"], "credentials": [{ "type": "password", "value": "dev-only-approver", "temporary": false }] },
    { "username": "settlement", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["settlement_operator"], "credentials": [{ "type": "password", "value": "dev-only-settlement", "temporary": false }] },
    { "username": "egress", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["egress_operator"], "credentials": [{ "type": "password", "value": "dev-only-egress", "temporary": false }] },
    { "username": "reconciliation", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["reconciliation_operator"], "credentials": [{ "type": "password", "value": "dev-only-reconciliation", "temporary": false }] },
    { "username": "case", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["case_operator"], "credentials": [{ "type": "password", "value": "dev-only-case", "temporary": false }] },
    { "username": "refdata", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["reference_data_admin"], "credentials": [{ "type": "password", "value": "dev-only-refdata", "temporary": false }] },
    { "username": "simulation", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["simulation_operator"], "credentials": [{ "type": "password", "value": "dev-only-simulation", "temporary": false }] },
    { "username": "auditor", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["auditor"], "credentials": [{ "type": "password", "value": "dev-only-auditor", "temporary": false }] },
    { "username": "security-admin", "enabled": true, "requiredActions": [], "attributes": { "branch_id": ["00000000-0000-0000-0000-000000000101"] }, "realmRoles": ["security_admin"], "credentials": [{ "type": "password", "value": "dev-only-security-admin", "temporary": false }] }
  ]
}
